  <h1 class="text-center text-3xl font-bold text-brand-green">About</h1>

  <div class="prose-page mt-8 grid gap-8 md:grid-cols-[2fr_5fr] md:items-start">
    <figure>
      <img
        src="/assets/uploads/editor/pa220310.jpeg"
