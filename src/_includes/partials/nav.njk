<header class="sticky top-0 z-40 border-b border-black/5 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 md:px-6">
    <a href="/" class="flex items-center gap-2 font-heading text-lg font-bold tracking-wide text-brand-green-deep">
      <svg class="h-6 w-6 shrink-0 text-brand-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 19c0-7 5-13 14-14 0 9-5 14-14 14Z" /><path d="M9 15c2-3 5-5 8-6" />
      </svg>
      <span>Ely <span class="text-brand-ink">Allotments &amp; Gardens</span></span>
    </a>

    <!-- Mobile toggle -->
    <button
      type="button"
      class="inline-flex items-center justify-center rounded p-2 text-brand-ink md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Menu -->
    <nav
      class="absolute inset-x-0 top-full hidden flex-col gap-1 border-b border-black/5 bg-white p-4 shadow-md md:static md:flex md:flex-row md:items-center md:gap-1 md:border-0 md:p-0 md:shadow-none"
      data-menu
      aria-label="Primary"
    >
      {% for item in nav.items %}
        {% set isCurrent = page.url == item.url %}
        <div class="group relative md:px-1">
          <a
            href="{{ item.url }}"
            class="block rounded px-3 py-2 font-heading text-sm font-medium uppercase tracking-wide transition hover:bg-brand-green/10 hover:text-brand-green
            {% if isCurrent %}text-brand-green{% else %}text-brand-ink{% endif %}"
            {% if isCurrent %}aria-current="page"{% endif %}
          >
            {{ item.title }}
          </a>

          {% if item.children %}
            <div
              class="md:invisible md:absolute md:left-0 md:top-full md:z-10 md:min-w-52 md:translate-y-1 md:rounded-md md:border md:border-black/5 md:bg-white md:p-1 md:opacity-0 md:shadow-lg md:transition group-hover:md:visible group-hover:md:translate-y-0 group-hover:md:opacity-100 group-focus-within:md:visible group-focus-within:md:translate-y-0 group-focus-within:md:opacity-100"
            >
              {% for child in item.children %}
                {% set childCurrent = page.url == child.url %}
                <a
                  href="{{ child.url }}"
                  class="block rounded px-3 py-2 pl-6 font-heading text-sm font-medium transition hover:bg-brand-green/10 hover:text-brand-green md:pl-3
                  {% if childCurrent %}text-brand-green{% else %}text-brand-ink/80{% endif %}"
                  {% if childCurrent %}aria-current="page"{% endif %}
                >
                  {{ child.title }}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {# Primary call to action — always visible, visually distinct. #}
      <div class="mt-2 md:ml-2 md:mt-0">
        <a
          href="{{ nav.cta.url }}"
          class="flex items-center justify-center gap-2 rounded-full bg-brand-green px-5 py-2.5 font-heading text-sm font-semibold uppercase tracking-wide text-white shadow-sm transition hover:bg-brand-green-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-green-deep"
          {% if page.url == nav.cta.url %}aria-current="page"{% endif %}
        >
          {{ nav.cta.title }}
        </a>
      </div>
    </nav>
  </div>
</header>
