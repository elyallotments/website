{# Organic section divider — a leaf-vine rule replacing bare <hr>.
   Usage: {% from "partials/divider.njk" import divider %} {{ divider() }}
   tone: green | gold | soil #}
{% macro divider(tone="green") %}
{%- if tone == "gold" -%}{%- set c = "text-brand-gold" -%}
{%- elif tone == "soil" -%}{%- set c = "text-brand-soil" -%}
{%- else -%}{%- set c = "text-brand-green-light" -%}{%- endif -%}
<div class="my-10 flex items-center justify-center gap-3 {{ c }}" role="separator" aria-hidden="true">
  <span class="h-px w-16 bg-current/50 sm:w-24"></span>
  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 19c0-7 5-13 14-14 0 9-5 14-14 14Z" /><path d="M9 15c2-3 5-5 8-6" />
  </svg>
  <span class="h-px w-16 bg-current/50 sm:w-24"></span>
</div>
{% endmacro %}
