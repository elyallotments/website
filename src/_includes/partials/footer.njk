<footer class="mt-16 border-t border-black/5 bg-brand-ink text-white/90">
  <div class="mx-auto max-w-6xl px-4 py-10 md:px-6">
    <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2" aria-label="Footer">
      {% for item in nav.footer %}
        <a href="{{ item.url }}" class="font-heading text-sm uppercase tracking-wide transition hover:text-brand-green-light">
          {{ item.title }}
        </a>
      {% endfor %}
    </nav>
    <p class="mt-8 text-center text-sm text-white/60">
      &copy; {% year %} {{ site.name }} Ltd. Run by volunteers on behalf of the City of Ely Council.
    </p>
  </div>
</footer>
