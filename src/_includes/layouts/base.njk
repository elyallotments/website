<!doctype html>
<html lang="{{ site.locale }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} — {{ site.shortName }}{% else %}{{ site.name }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..600&family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-brand-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-brand-green focus:px-4 focus:py-2 focus:text-white"
      >Skip to content</a
    >

    {% include "partials/nav.njk" %}

    <main id="main" class="flex-1">
      {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    {# Shared full-screen photo viewer — populated and controlled by site.js. #}
    <div
      id="lightbox"
      class="fixed inset-0 z-50 hidden items-center justify-center opacity-0 transition-opacity duration-200 motion-reduce:transition-none"
      data-lightbox
      role="dialog"
      aria-modal="true"
      aria-label="Photo viewer"
      aria-hidden="true"
    >
      <div class="absolute inset-0 bg-black/90" data-lightbox-backdrop></div>

      <button type="button" class="absolute right-3 top-3 z-10 rounded-full bg-white/10 p-2 text-white transition hover:bg-white/20" data-lightbox-close aria-label="Close photo viewer">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>

      <button type="button" class="absolute left-3 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white/10 p-2 text-white transition hover:bg-white/20 md:p-3" data-lightbox-prev aria-label="Previous photo">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button type="button" class="absolute right-3 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white/10 p-2 text-white transition hover:bg-white/20 md:p-3" data-lightbox-next aria-label="Next photo">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>

      <figure class="relative z-0 m-0 flex max-h-screen max-w-[92vw] flex-col items-center px-4 py-12">
        <img data-lightbox-img alt="" class="max-h-[80vh] max-w-full scale-95 rounded-lg object-contain shadow-2xl transition duration-200 motion-reduce:transition-none" />
        <figcaption class="mt-3 max-w-2xl text-center text-sm text-white/80" data-lightbox-caption></figcaption>
      </figure>

      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm tracking-wide text-white/70" data-lightbox-counter></div>
    </div>

    <script src="/js/site.js" defer></script>
  </body>
</html>
